# Supabase — get these from your Supabase project settings (Project Settings > API).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI provider. The OpenAI key MUST live server-side (Supabase Edge Function), never in the app bundle.
# The app talks to an Edge Function; this var is only for local Edge Function development.
OPENAI_API_KEY=sk-your-openai-key

# Optional: override which model the blueprint/coach uses.
AI_MODEL=gpt-4o-mini
